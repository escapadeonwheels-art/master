{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "content": {
      "type": "blocks"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "slug": {
      "type": "uid"
    },
    "type": {
      "type": "string"
    },
    "subtype": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "price": {
      "type": "string"
    },
    "rating": {
      "type": "string"
    },
    "reviews": {
      "type": "text"
    },
    "host": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "featured": {
      "type": "string"
    }
  }
}
